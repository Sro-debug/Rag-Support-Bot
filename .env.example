# Copy to .env — never commit .env to git

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
ADMIN_EMAIL=admin@support.local
ADMIN_PASSWORD=change-me-before-deploy

# ─── Models ───────────────────────────────────────────────────────────────────
# Chat model pulled into Ollama: llama3 | mistral | gemma | phi3
CHAT_MODEL=llama3
# Embedding model: must support /api/embeddings in Ollama
EMBED_MODEL=nomic-embed-text

# ─── Service URLs (internal Docker network) ───────────────────────────────────
# These are used inside the Docker network — do not change unless running bare-metal
CHROMA_URL=http://chromadb:8000
OLLAMA_URL=http://ollama:11434
RAG_SERVICE_URL=http://rag-service:8080

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=http://localhost
UPLOAD_DIR=/app/uploads
